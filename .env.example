# ============================================================
# MENOSFRANGO — Variáveis de Ambiente
# Copie para .env e preencha com seus valores
# NUNCA commite o .env no Git!
# ============================================================

APP_ENV=local
APP_NAME=MENOSFRANGO
DEBUG=true
API_PORT=8000

# ── JWT ──────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=troca-isso-por-algo-secreto-aqui
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7

# ── Banco de Dados ────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/menosfrango
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL (Docker) ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=menosfrango

# ── MinIO (Storage de fotos e PDFs) ──────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=menosfrango-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# ── IA ────────────────────────────────────────────────────────
# Modo A: offline (grátis, sem API)
# Modo B: Ollama local
# Modo C: OpenAI ou Anthropic (pago)
FEATURE_FLAG_IA_MODE=A
OLLAMA_ENDPOINT=http://ollama:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── E-mail ────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@menosfrango.ai
EMAIL_DEV_LOG=true

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
